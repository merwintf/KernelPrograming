private void EnsureWindowInsideMonitor(IntPtr monitorHandle)
{
    var info = new MONITORINFO
    {
        cbSize = Marshal.SizeOf<MONITORINFO>()
    };

    if (!GetMonitorInfo(monitorHandle, ref info))
        return;

    var source = PresentationSource.FromVisual(this);
    if (source?.CompositionTarget == null)
        return;

    var transform = source.CompositionTarget.TransformFromDevice;

    Point topLeft = transform.Transform(new Point(info.rcWork.Left, info.rcWork.Top));
    Point bottomRight = transform.Transform(new Point(info.rcWork.Right, info.rcWork.Bottom));

    double screenLeft = topLeft.X;
    double screenTop = topLeft.Y;
    double screenRight = bottomRight.X;
    double screenBottom = bottomRight.Y;

    double screenWidth = screenRight - screenLeft;
    double screenHeight = screenBottom - screenTop;

    double windowWidth = double.IsNaN(Width) ? ActualWidth : Width;
    double windowHeight = double.IsNaN(Height) ? ActualHeight : Height;

    if (windowWidth > screenWidth)
    {
        Width = screenWidth;
        windowWidth = screenWidth;
    }

    if (windowHeight > screenHeight)
    {
        Height = screenHeight;
        windowHeight = screenHeight;
    }

    if (Left < screenLeft)
        Left = screenLeft;

    if (Top < screenTop)
        Top = screenTop;

    if (Left + windowWidth > screenRight)
        Left = screenRight - windowWidth;

    if (Top + windowHeight > screenBottom)
        Top = screenBottom - windowHeight;
}
